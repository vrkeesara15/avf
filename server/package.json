{
  "name": "akshaya-vidya-foundation-api",
  "version": "1.0.0",
  "description": "Backend API for the Akshaya Vidya Foundation web application (GCP Cloud Run + Firestore).",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
