# ---------------------------------------------------------------------------
# Akshaya Vidya Foundation API — environment configuration
# Copy to `.env` for local development. On GCP, set these via Secret Manager.
# ---------------------------------------------------------------------------

# Server
PORT=8080
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (the public site + admin)
CORS_ORIGINS=http://localhost:5173

# Data store: "memory" (no GCP needed) or "firestore"
DATA_STORE=memory

# Google Cloud / Firestore
GCP_PROJECT_ID=avf-foundation
# For local dev against the Firestore emulator, set:
# FIRESTORE_EMULATOR_HOST=localhost:8081
# In Cloud Run, Application Default Credentials are used automatically.
# Locally you can point to a service-account key:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Cloud Storage (gallery uploads). Falls back to local disk when unset.
GCS_BUCKET=

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
# Seeded super-admin (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@akshayavidya.org
SEED_ADMIN_PASSWORD=ChangeMe!2025

# Razorpay (leave blank to run in deterministic TEST mode — no real charges)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=test_secret

# Email (SMTP). Leave blank to use a no-op JSON transport that logs receipts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Akshaya Vidya Foundation <no-reply@akshayavidya.org>"
